{
  "name": "khelaghor-server",
  "version": "1.0.0",
  "description": "",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsup src/server.ts --watch --clean --format esm --onSuccess \"node dist/server.js\"",
    "build": "tsup src/server.ts --format esm --clean --minify",
    "start": "node dist/server.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:all": "npm run db:migrate && npm run db:generate",
    "db:reset": "prisma migrate reset",
    "db:deploy": "prisma migrate deploy",
    "db:push": "npx prisma db push",
    "db:studio": "prisma studio",
    "postinstall": "prisma generate",
    "render-build": "npm install --include=dev && npx prisma generate && npx prisma migrate deploy && npm run build"
  },
  "keywords": [],
  "author": "Emon howlader",
  "license": "ISC",
  "type": "module",
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^25.3.3",
    "@types/nodemailer": "^7.0.11",
    "@types/pg": "^8.18.0",
    "@types/streamifier": "^0.1.2",
    "prisma": "^7.4.2",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "@types/passport": "^1.0.17",
    "@types/passport-google-oauth20": "^2.0.17",
    "axios": "^1.13.6",
    "barikoiapis": "^1.0.8",
    "bcrypt": "^6.0.0",
    "cloudinary": "^2.9.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "date-fns": "^4.1.0",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.0",
    "nodemailer": "^8.0.2",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "pg": "^8.19.0",
    "redis": "^5.11.0",
    "streamifier": "^0.1.1",
    "zod": "^4.3.6"
  }
}
